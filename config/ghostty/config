# Ghostty Configuration File
# https://ghostty.org/docs/config/reference

# Main UI
# theme = dark:Catppuccin Mocha,light:Catppuccin Frappe
theme = dark:Lovelace,light:Catppuccin Frappe
# theme = dark:Spacedust,light:Catppuccin Frappe
# theme = dark:Zenburn,light:Catppuccin Frappe
macos-titlebar-style = hidden
maximize = true
window-padding-color = extend
window-padding-y = 0

# Font
font-family = "MartianMono Nerd Font"
font-family-bold = "MartianMono Nerd Font"
font-family-italic = "MartianMono Nerd Font"
font-family-bold-italic = "MartianMono Nerd Font"
font-size = 18
font-thicken = true

# Cursor
shell-integration-features = no-cursor
cursor-style = block
cursor-style-blink = false
cursor-color = #86EFD1
cursor-opacity = 0.8
mouse-hide-while-typing = true

# Terminal
term = xterm-256color

# Misc
link-url = true
link-previews = true

bell-features = no-system, no-audio, no-title, no-border, no-attention
